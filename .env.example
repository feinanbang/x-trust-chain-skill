# Copy this file to .env and fill in YOUR OWN X (Twitter) API keys.
# Get them at https://developer.x.com (free tier works; ~100 reads/month).
# The .env file is gitignored — your keys never leave your machine.
#
# You need ONE of the two auth modes below.

# --- Mode 1: OAuth 1.0a user context (recommended; required by some endpoints) ---
X_API_KEY=YOUR_API_KEY_HERE
X_API_SECRET=YOUR_API_SECRET_HERE
X_ACCESS_TOKEN=YOUR_ACCESS_TOKEN_HERE
X_ACCESS_SECRET=YOUR_ACCESS_SECRET_HERE

# --- Mode 2: App-only bearer token (simpler, read-only) ---
# X_BEARER_TOKEN=YOUR_BEARER_TOKEN_HERE

# --- Optional: only if your network needs a proxy to reach api.twitter.com ---
# HTTPS_PROXY=http://127.0.0.1:7890
